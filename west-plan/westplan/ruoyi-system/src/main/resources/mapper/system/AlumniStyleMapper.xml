<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AlumniStyleMapper">
    
    <resultMap type="AlumniStyle" id="AlumniStyleResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="styleName"    column="style_name"    />
        <result property="styleType"    column="style_type"    />
        <result property="styleContent"    column="style_content"    />
        <result property="styleAttach"    column="style_attach"    />
        <result property="sort"    column="sort"    />
        <result property="isPublic"    column="is_public"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectAlumniStyleVo">
        select id, user_id, style_name, style_type, style_content, style_attach, sort, is_public, create_time, update_time from alumni_style
    </sql>

    <select id="selectAlumniStyleList" parameterType="AlumniStyle" resultMap="AlumniStyleResult">
        <include refid="selectAlumniStyleVo"/>
        <where>  
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="styleName != null  and styleName != ''"> and style_name like concat('%', #{styleName}, '%')</if>
            <if test="styleType != null "> and style_type = #{styleType}</if>
            <if test="styleContent != null  and styleContent != ''"> and style_content = #{styleContent}</if>
            <if test="styleAttach != null  and styleAttach != ''"> and style_attach = #{styleAttach}</if>
            <if test="sort != null "> and sort = #{sort}</if>
            <if test="isPublic != null "> and is_public = #{isPublic}</if>
        </where>
    </select>
    
    <select id="selectAlumniStyleById" parameterType="Long" resultMap="AlumniStyleResult">
        <include refid="selectAlumniStyleVo"/>
        where id = #{id}
    </select>

    <insert id="insertAlumniStyle" parameterType="AlumniStyle" useGeneratedKeys="true" keyProperty="id">
        insert into alumni_style
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="styleName != null">style_name,</if>
            <if test="styleType != null">style_type,</if>
            <if test="styleContent != null">style_content,</if>
            <if test="styleAttach != null and styleAttach != ''">style_attach,</if>
            <if test="sort != null">sort,</if>
            <if test="isPublic != null">is_public,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="styleName != null">#{styleName},</if>
            <if test="styleType != null">#{styleType},</if>
            <if test="styleContent != null">#{styleContent},</if>
            <if test="styleAttach != null and styleAttach != ''">#{styleAttach},</if>
            <if test="sort != null">#{sort},</if>
            <if test="isPublic != null">#{isPublic},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateAlumniStyle" parameterType="AlumniStyle">
        update alumni_style
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="styleName != null">style_name = #{styleName},</if>
            <if test="styleType != null">style_type = #{styleType},</if>
            <if test="styleContent != null">style_content = #{styleContent},</if>
            <if test="styleAttach != null and styleAttach != ''">style_attach = #{styleAttach},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="isPublic != null">is_public = #{isPublic},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAlumniStyleById" parameterType="Long">
        delete from alumni_style where id = #{id}
    </delete>

    <delete id="deleteAlumniStyleByIds" parameterType="String">
        delete from alumni_style where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>