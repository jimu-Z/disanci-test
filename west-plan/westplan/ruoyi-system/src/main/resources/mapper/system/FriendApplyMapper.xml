<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.FriendApplyMapper">

    <!-- 结果映射 -->
    <resultMap id="FriendApplyResultMap" type="FriendApply">
        <id property="id" column="id" />
        <result property="applyUserId" column="apply_user_id" />
        <result property="targetUserId" column="target_user_id" />
        <result property="applyMsg" column="apply_msg" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="applyUserName" column="apply_user_name" />
        <result property="targetUserName" column="target_user_name" />
        <result property="applyUserAvatar" column="apply_user_avatar" />
        <result property="targetUserAvatar" column="target_user_avatar" />
    </resultMap>

    <!-- ===================== 基础CRUD ===================== -->
    <!-- 发起好友申请 -->
    <insert id="insertApply" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO friend_apply (apply_user_id, target_user_id, apply_msg, status)
        VALUES (#{applyUserId}, #{targetUserId}, #{applyMsg}, 1)
    </insert>

    <!-- 根据ID查询申请 -->
    <select id="selectById" resultMap="FriendApplyResultMap">
        SELECT * FROM friend_apply WHERE id = #{id}
    </select>

    <!-- 修改申请状态 -->
    <update id="updateApplyStatus">
        UPDATE friend_apply
        SET status = #{status}
        WHERE id = #{id}
    </update>

    <!-- 检查是否已存在待处理申请 -->
    <select id="checkExistApply" resultMap="FriendApplyResultMap">
        SELECT *
        FROM friend_apply
        WHERE apply_user_id = #{applyUserId}
          AND target_user_id = #{targetUserId}
          AND status = 1
    </select>

    <!-- 查询我收到的好友申请（关联申请人信息） -->
    <select id="selectMyReceiveApply" resultMap="FriendApplyResultMap">
        SELECT
            a.*,
            s.user_name AS apply_user_name
        FROM friend_apply a
                 LEFT JOIN student_admission s
                           ON a.apply_user_id = s.id
        WHERE a.target_user_id = #{targetUserId}
          AND a.status = 1
        ORDER BY a.create_time DESC
    </select>

    <!--    查询我所发出的好友申请（处于申请状态）-->
    <select id="selectMySendApply" resultMap="FriendApplyResultMap">
        SELECT
        a.*,
        s.user_name AS target_user_name
        FROM friend_apply a
        LEFT JOIN student_admission s ON a.target_user_id = s.id
        WHERE a.apply_user_id = #{applyUserId}
        AND a.status = 1
    </select>

</mapper>