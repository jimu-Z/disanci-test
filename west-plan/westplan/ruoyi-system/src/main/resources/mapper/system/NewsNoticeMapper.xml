<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.NewsNoticeMapper">
    
    <resultMap type="NewsNotice" id="NewsNoticeResult">
        <result property="id"    column="id"    />
        <result property="noticeType"    column="notice_type"    />
        <result property="noticeTitle"    column="notice_title"    />
        <result property="noticeContent"    column="notice_content"    />
        <result property="noticeAttach"    column="notice_attach"    />
        <result property="publishScope"    column="publish_scope"    />
        <result property="isTop"    column="is_top"    />
        <result property="publishBy"    column="publish_by"    />
        <result property="publishTime"    column="publish_time"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectNewsNoticeVo">
        select id, notice_type, notice_title, notice_content, notice_attach, publish_scope, is_top, publish_by, publish_time, status, create_time, update_time from news_notice
    </sql>

    <select id="selectNewsNoticeList" parameterType="NewsNotice" resultMap="NewsNoticeResult">
        <include refid="selectNewsNoticeVo"/>
        <where>  
            <if test="noticeType != null "> and notice_type = #{noticeType}</if>
            <if test="noticeTitle != null  and noticeTitle != ''"> and notice_title = #{noticeTitle}</if>
            <if test="noticeContent != null  and noticeContent != ''"> and notice_content = #{noticeContent}</if>
            <if test="noticeAttach != null  and noticeAttach != ''"> and notice_attach = #{noticeAttach}</if>
            <if test="publishScope != null  and publishScope != ''"> and publish_scope = #{publishScope}</if>
            <if test="isTop != null "> and is_top = #{isTop}</if>
            <if test="publishBy != null  and publishBy != ''"> and publish_by = #{publishBy}</if>
            <if test="publishTime != null "> and publish_time = #{publishTime}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectNewsNoticeById" parameterType="Long" resultMap="NewsNoticeResult">
        <include refid="selectNewsNoticeVo"/>
        where id = #{id}
    </select>

    <insert id="insertNewsNotice" parameterType="NewsNotice" useGeneratedKeys="true" keyProperty="id">
        insert into news_notice
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="noticeType != null">notice_type,</if>
            <if test="noticeTitle != null and noticeTitle != ''">notice_title,</if>
            <if test="noticeContent != null and noticeContent != ''">notice_content,</if>
            <if test="noticeAttach != null">notice_attach,</if>
            <if test="publishScope != null">publish_scope,</if>
            <if test="isTop != null">is_top,</if>
            <if test="publishBy != null and publishBy != ''">publish_by,</if>
            <if test="publishTime != null">publish_time,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="noticeType != null">#{noticeType},</if>
            <if test="noticeTitle != null and noticeTitle != ''">#{noticeTitle},</if>
            <if test="noticeContent != null and noticeContent != ''">#{noticeContent},</if>
            <if test="noticeAttach != null">#{noticeAttach},</if>
            <if test="publishScope != null">#{publishScope},</if>
            <if test="isTop != null">#{isTop},</if>
            <if test="publishBy != null and publishBy != ''">#{publishBy},</if>
            <if test="publishTime != null">#{publishTime},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateNewsNotice" parameterType="NewsNotice">
        update news_notice
        <trim prefix="SET" suffixOverrides=",">
            <if test="noticeType != null">notice_type = #{noticeType},</if>
            <if test="noticeTitle != null and noticeTitle != ''">notice_title = #{noticeTitle},</if>
            <if test="noticeContent != null and noticeContent != ''">notice_content = #{noticeContent},</if>
            <if test="noticeAttach != null">notice_attach = #{noticeAttach},</if>
            <if test="publishScope != null">publish_scope = #{publishScope},</if>
            <if test="isTop != null">is_top = #{isTop},</if>
            <if test="publishBy != null and publishBy != ''">publish_by = #{publishBy},</if>
            <if test="publishTime != null">publish_time = #{publishTime},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteNewsNoticeById" parameterType="Long">
        delete from news_notice where id = #{id}
    </delete>

    <delete id="deleteNewsNoticeByIds" parameterType="String">
        delete from news_notice where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>