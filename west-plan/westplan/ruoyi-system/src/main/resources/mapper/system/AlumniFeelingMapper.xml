<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AlumniFeelingMapper">
    
    <resultMap type="AlumniFeeling" id="AlumniFeelingResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="category"    column="category"    />
        <result property="title"    column="title"    />
        <result property="content"    column="content"    />
        <result property="picture"    column="picture"    />
        <result property="vedio"    column="vedio"    />
        <result property="viewCount"    column="view_count"    />
        <result property="likeCount"    column="like_count"    />
        <result property="isPublic"    column="is_public"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="showOrder"    column="show_order"    />
    </resultMap>
    <resultMap type="FeelingWithUser" id="FeelingWithUserResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="category"    column="category"    />
        <result property="title"    column="title"    />
        <result property="content"    column="content"    />
        <result property="picture"    column="picture"    />
        <result property="vedio"    column="vedio"    />
        <result property="viewCount"    column="view_count"    />
        <result property="likeCount"    column="like_count"    />
        <result property="isPublic"    column="is_public"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="showOrder"    column="show_order"    />
        <result property="avatar"    column="avatar"    />
        <result property="author"    column="nick_name"    />
    </resultMap>


    <sql id="selectAlumniFeelingVo">
        select id, user_id, category, title, content, picture, vedio, view_count, like_count, is_public, create_time, update_time, show_order from alumni_feeling
    </sql>

    <select id="selectAlumniFeelingList" parameterType="AlumniFeeling" resultMap="AlumniFeelingResult">
        <include refid="selectAlumniFeelingVo"/>
        <where>  
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="category != null  and category != ''"> and category = #{category}</if>
            <if test="title != null  and title != ''"> and title = #{title}</if>
            <if test="content != null  and content != ''"> and content = #{content}</if>
            <if test="picture != null  and picture != ''"> and picture = #{picture}</if>
            <if test="vedio != null  and vedio != ''"> and vedio = #{vedio}</if>
            <if test="viewCount != null "> and view_count = #{viewCount}</if>
            <if test="likeCount != null "> and like_count = #{likeCount}</if>
            <if test="isPublic != null  and isPublic != ''"> and is_public = #{isPublic}</if>
            <if test="showOrder != null "> and show_order = #{showOrder}</if>
        </where>
    </select>
    <select id="selectFeelingWithUserList" parameterType="AlumniFeeling" resultMap="FeelingWithUserResult">
        SELECT A.id, A.user_id, category, title, content, picture, vedio, view_count, like_count, is_public, A.create_time, A.update_time, show_order,B.avatar,B.nick_name FROM alumni_feeling A
        JOIN sys_user B ON A.user_id=B.user_id
        <where>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="category != null  and category != ''"> and category = #{category}</if>
            <if test="title != null  and title != ''"> and title = #{title}</if>
            <if test="content != null  and content != ''"> and content = #{content}</if>
            <if test="picture != null  and picture != ''"> and picture = #{picture}</if>
            <if test="vedio != null  and vedio != ''"> and vedio = #{vedio}</if>
            <if test="viewCount != null "> and view_count = #{viewCount}</if>
            <if test="likeCount != null "> and like_count = #{likeCount}</if>

            <if test="showOrder != null "> and show_order = #{showOrder} </if>
             and is_public ='是'
        </where>
        ORDER BY  A.create_time desc
    </select>
    <!-- 查询感悟总数 -->
    <select id="selectFeelingCount" parameterType="AlumniFeeling" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM alumni_feeling
        <where>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="category != null  and category != ''"> and category = #{category}</if>
            <if test="title != null  and title != ''"> and title = #{title}</if>
            <if test="content != null  and content != ''"> and content = #{content}</if>
            <if test="picture != null  and picture != ''"> and picture = #{picture}</if>
            <if test="vedio != null  and vedio != ''"> and vedio = #{vedio}</if>
            <if test="viewCount != null "> and view_count = #{viewCount}</if>
            <if test="likeCount != null "> and like_count = #{likeCount}</if>
            <if test="isPublic != null  and isPublic != ''"> and is_public = #{isPublic}</if>
            <if test="showOrder != null "> and show_order = #{showOrder}</if>
        </where>
    </select>
    <select id="selectAlumniFeelingById" parameterType="Long" resultMap="AlumniFeelingResult">
        <include refid="selectAlumniFeelingVo"/>
        where id = #{id}
    </select>

    <insert id="insertAlumniFeeling" parameterType="AlumniFeeling" useGeneratedKeys="true" keyProperty="id">
        insert into alumni_feeling
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="category != null and category != ''">category,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="picture != null">picture,</if>
            <if test="vedio != null">vedio,</if>
            <if test="viewCount != null">view_count,</if>
            <if test="likeCount != null">like_count,</if>
            <if test="isPublic != null and isPublic != ''">is_public,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="showOrder != null">show_order,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="category != null and category != ''">#{category},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="picture != null">#{picture},</if>
            <if test="vedio != null">#{vedio},</if>
            <if test="viewCount != null">#{viewCount},</if>
            <if test="likeCount != null">#{likeCount},</if>
            <if test="isPublic != null and isPublic != ''">#{isPublic},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="showOrder != null">#{showOrder},</if>
         </trim>
    </insert>

    <update id="updateAlumniFeeling" parameterType="AlumniFeeling">
        update alumni_feeling
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="category != null and category != ''">category = #{category},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="picture != null">picture = #{picture},</if>
            <if test="vedio != null">vedio = #{vedio},</if>
            <if test="viewCount != null">view_count = #{viewCount},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="isPublic != null and isPublic != ''">is_public = #{isPublic},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="showOrder != null">show_order = #{showOrder},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAlumniFeelingById" parameterType="Long">
        delete from alumni_feeling where id = #{id}
    </delete>

    <delete id="deleteAlumniFeelingByIds" parameterType="String">
        delete from alumni_feeling where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <!-- 更新点赞数 -->
    <update id="updateLikeCount">
        UPDATE alumni_feeling
        SET like_count = like_count + #{count}
        WHERE id = #{id}
    </update>

    <!-- 更新评论数 -->
    <update id="incrementViewCount">
        UPDATE alumni_feeling
        SET view_count = view_count + 1
        WHERE id = #{id}
    </update>
</mapper>